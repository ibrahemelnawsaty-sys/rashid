APP_NAME="رشيد"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.com
APP_TIMEZONE=Asia/Riyadh

APP_LOCALE=ar
APP_FALLBACK_LOCALE=ar
APP_FAKER_LOCALE=ar_SA

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

# قاعدة بيانات Hostinger — MySQL (املأ القيم من hPanel)
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=uXXXXXXXX_rashid
DB_USERNAME=uXXXXXXXX_user
DB_PASSWORD=

# لا Redis على الاستضافة المشتركة — كل شيء عبر قاعدة البيانات/الملفات
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

MAIL_MAILER=log
MAIL_FROM_ADDRESS="no-reply@your-domain.com"
MAIL_FROM_NAME="${APP_NAME}"

# طبقة الذكاء الاصطناعي (اختيارية) — Claude API
ANTHROPIC_API_KEY=
AI_ADVISOR_MODEL=claude-haiku-4-5-20251001

VITE_APP_NAME="${APP_NAME}"
